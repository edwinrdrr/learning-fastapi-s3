# Only needed if you run the app OUTSIDE docker. Inside compose these are set
# for you. To point at REAL AWS S3 later: remove S3_ENDPOINT_URL (so boto3 uses
# the real AWS endpoint) and use real AWS credentials.
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_REGION=us-east-1
S3_BUCKET=readings
